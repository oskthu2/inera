{
  "resourceType": "StructureDefinition",
  "id": "LMALakemedelsoverlamnande",
  "url": "https://sis.se/fhir/lma/StructureDefinition/LMALakemedelsoverlamnande",
  "name": "LMALakemedelsoverlamnande",
  "title": "LMA Läkemedelsöverlämnande",
  "status": "draft",
  "description": "Automatens överlämning av läkemedel vid schemalagd tidpunkt.\nLager: enhetslager.\n\nAutomaten **överlämnar** – den administrerar inte. Klassen benämns\nLäkemedelsöverlämnande för att skilja automatens handling från apotekets\ndosförpackande (dosdispensering). Se ANMÄRKNING i standardens avsnitt 6.4.7.\n\n**Lageruppdelning av felkoder:**\n- `notPerformedReason` (felkod) tillhör **enhetslagret**: mekaniskt-fel, produkt-slut, sensorfel.\n- Dessa koder ska **inte** förekomma i `MedicationAdministration.statusReason`\n  (omvårdnadslagret).",
  "fhirVersion": "5.0.0",
  "kind": "resource",
  "abstract": false,
  "type": "MedicationDispense",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/MedicationDispense",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "MedicationDispense.status",
        "path": "MedicationDispense.status",
        "short": "Utfäll (enhetslager)",
        "comment": "Rapporteras av automaten. Konceptmappning: completed=lyckad, declined=misslyckad, unknown=okänt. Se LMA-koder i CodeSystem/lma-overlamningstfall.",
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.notPerformedReason",
        "path": "MedicationDispense.notPerformedReason",
        "short": "Felkod (enhetslager) – VS-Overlamninsfelkod Preferred",
        "comment": "SHOULD anges när status = misslyckad.\nTillhör **enhetslagret**: mekaniskt-fel | produkt-slut | sensorfel | okänt.\nBlanda INTE med omvårdnadslager-orsaker (MedicationAdministration.statusReason).\n`notPerformedReason` (CodeableReference) ersätter `statusReason[x]` från R4.",
        "mustSupport": true,
        "binding": {
          "strength": "preferred",
          "valueSet": "https://sis.se/fhir/lma/ValueSet/VS-Overlamninsfelkod"
        }
      },
      {
        "id": "MedicationDispense.medication",
        "path": "MedicationDispense.medication",
        "short": "Läkemedel (referens till Dospåse/Medication eller kod)",
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.subject",
        "path": "MedicationDispense.subject",
        "short": "Brukare",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://sis.se/fhir/lma/StructureDefinition/LMABrukare"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.performer",
        "path": "MedicationDispense.performer",
        "short": "Automat som genomförde överlämningen",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.performer.actor",
        "path": "MedicationDispense.performer.actor",
        "short": "Reference(LMAAutomat)",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://sis.se/fhir/lma/StructureDefinition/LMAAutomat"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.authorizingPrescription",
        "path": "MedicationDispense.authorizingPrescription",
        "short": "Bakomliggande ordination (valfri)",
        "comment": "MAY referera till MedicationRequest. LMA-system behöver inte ha kännedom om ordinationen.",
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.whenHandedOver",
        "path": "MedicationDispense.whenHandedOver",
        "short": "Faktisk tidpunkt för överlämning",
        "comment": "SHOULD anges om överlämning genomfördes (status=lyckad).",
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.dosageInstruction",
        "path": "MedicationDispense.dosageInstruction",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.dosageInstruction.timing",
        "path": "MedicationDispense.dosageInstruction.timing",
        "mustSupport": true
      },
      {
        "id": "MedicationDispense.dosageInstruction.timing.event",
        "path": "MedicationDispense.dosageInstruction.timing.event",
        "short": "Planerad tidpunkt för överlämning (SHALL)",
        "comment": "SHALL anges med minst en planerad överlämnandetidpunkt.\n`whenHandedOver` representerar faktisk tidpunkt; planerad tidpunkt anges i\n`dosageInstruction.timing.event` (Dosage.timing.event i R5).",
        "min": 1,
        "mustSupport": true
      }
    ]
  }
}
