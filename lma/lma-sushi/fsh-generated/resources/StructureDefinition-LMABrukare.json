{
  "resourceType": "StructureDefinition",
  "id": "LMABrukare",
  "url": "https://sis.se/fhir/lma/StructureDefinition/LMABrukare",
  "name": "LMABrukare",
  "title": "LMA Brukare",
  "status": "draft",
  "description": "Brukare med insatsen läkemedelsautomat inom socialtjänst och\nkommunal hälso- och sjukvård. Lager: omvårdnadslager.\n\nI PDL-kontext benämns samma person *patient*; FHIR-resursen Patient används\ni båda sammanhangen. Ankarpunkten för alla personrelaterade händelseresurser.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Patient",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Patient",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Patient.meta.lastUpdated",
        "path": "Patient.meta.lastUpdated",
        "short": "Tidpunkt för senaste förändring av brukarposten",
        "comment": "SHALL anges för att möjliggöra inkrementell hämtning. HSLF-FS 2016:40.",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier",
        "path": "Patient.identifier",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "system"
            }
          ],
          "rules": "open"
        },
        "short": "Unik identifierare",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:lmaId",
        "path": "Patient.identifier",
        "sliceName": "lmaId",
        "short": "LMA-systemets interna id",
        "definition": "Stabil, systemunik identifierare för brukaren i LMA-plattformen.",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:lmaId.system",
        "path": "Patient.identifier.system",
        "min": 1,
        "patternUri": "https://sis.se/fhir/lma/id/brukare"
      },
      {
        "id": "Patient.identifier:lmaId.value",
        "path": "Patient.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:personnummer",
        "path": "Patient.identifier",
        "sliceName": "personnummer",
        "short": "Personnummer (PDL 3:2§)",
        "comment": "SHOULD anges om tillgängligt.\nSkyddas av PDL 3:2§ – tillgång kräver ändamålsbegränsad behörighet.\nSe avsnitt 6.4.2 i standarden för GDPR art. 5.1.c.",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:personnummer.system",
        "path": "Patient.identifier.system",
        "min": 1,
        "patternUri": "http://electronichealth.se/id/personnummer"
      },
      {
        "id": "Patient.identifier:personnummer.value",
        "path": "Patient.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.active",
        "path": "Patient.active",
        "short": "Aktiv insats",
        "definition": "true om brukaren har aktiv insats med läkemedelsautomat. false om insatsen är avslutad.",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.name",
        "path": "Patient.name",
        "short": "Namn (valfritt – GDPR art. 5.1.c)",
        "comment": "MAY anges. Dataminimeringsprincipen innebär att namn inte ska lagras om ID-referens räcker.",
        "mustSupport": true
      },
      {
        "id": "Patient.telecom",
        "path": "Patient.telecom",
        "short": "Kontaktuppgifter (valfritt)",
        "mustSupport": true
      },
      {
        "id": "Patient.managingOrganization",
        "path": "Patient.managingOrganization",
        "short": "Ansvarig enhet (HSA-id)",
        "comment": "Reference till Organisation med\nidentifier.system = urn:oid:1.2.752.129.2.1.4.1 (HSA-katalogen).\nPDL 1:3§ kräver att ansvarig enhet kan identifieras.",
        "min": 1,
        "mustSupport": true
      }
    ]
  }
}
