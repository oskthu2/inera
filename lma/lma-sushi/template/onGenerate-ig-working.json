kärnprofiler."}],"resource":[{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"MedicationAdministration"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"MedicationAdministration-example-administrering-avbojde-01.html"}],"reference":{"reference":"MedicationAdministration/example-administrering-avbojde-01"},"name":"Exempeladministrering – brukare avböjde (omvårdnadslager)","description":"Exempelinstans för LMALakemedelsadministrering där brukaren avböjde.\nVisar korrekt lageruppdelning: orsaken är omvårdnadsbedömd och från omvårdnadslagrets VS.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMALakemedelsadministrering"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"MedicationAdministration"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"MedicationAdministration-example-administrering-01.html"}],"reference":{"reference":"MedicationAdministration/example-administrering-01"},"name":"Exempeladministrering – genomförd av sjuksköterska","description":"Exempelinstans för LMALakemedelsadministrering. Kopplar till föregående överlämning.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMALakemedelsadministrering","groupingId":"Examples"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"Device"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"Device-example-automat-01.html"}],"reference":{"reference":"Device/example-automat-01"},"name":"Exempelautomat – MedRobot 3000","description":"Exempelinstans för LMAAutomat med driftsstatus och batterinivå.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMAAutomat","groupingId":"Examples"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"Patient"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"Patient-example-brukare-01.html"}],"reference":{"reference":"Patient/example-brukare-01"},"name":"Exempelbrukare – Erik Svensson","description":"Exempelinstans för LMABrukare. Personnummer och namn är fiktiva.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMABrukare","groupingId":"Examples"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"DeviceUseStatement"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"DeviceUseStatement-example-koppling-01.html"}],"reference":{"reference":"DeviceUseStatement/example-koppling-01"},"name":"Exempelkoppling – brukare 4711 till automat 0042","description":"Exempelinstans för LMAKoppling. Aktiv koppling sedan 2025-01-15.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMAKoppling","groupingId":"Examples"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"SupplyDelivery"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"SupplyDelivery-example-pafyllnad-01.html"}],"reference":{"reference":"SupplyDelivery/example-pafyllnad-01"},"name":"Exempelpåfyllnad – dosrulle batch 2024-LM-9912","description":"Exempelinstans för LMAPafyllnad med batchnummer för spårbarhet.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMAPafyllnad","groupingId":"Examples"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"MedicationDispense"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"MedicationDispense-example-overlamnande-01.html"}],"reference":{"reference":"MedicationDispense/example-overlamnande-01"},"name":"Exempelöverlämning – lyckad, 2025-06-15 08:00","description":"Exempelinstans för LMALakemedelsoverlamnande. Planerad och genomförd överlämning.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMALakemedelsoverlamnande","groupingId":"Examples"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"MedicationDispense"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"MedicationDispense-example-overlamnande-misslyckad-01.html"}],"reference":{"reference":"MedicationDispense/example-overlamnande-misslyckad-01"},"name":"Exempelöverlämning – misslyckad, mekaniskt fel","description":"Exempelinstans för LMALakemedelsoverlamnande med felkod från enhetslagret.","exampleCanonical":"https://sis.se/fhir/lma/StructureDefinition/LMALakemedelsoverlamnande"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"CodeSystem-lma-administreringsorsak.html"}],"reference":{"reference":"CodeSystem/lma-administreringsorsak"},"name":"LMA Administreringsorsak","description":"Orsak till utebliven eller avbruten läkemedelsadministrering.\n**Omvårdnadslager.** Bedöms och dokumenteras av hälso- och sjukvårdspersonal.","exampleBoolean":false,"groupingId":"Terminology"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"CodeSystem-lma-administreringsstatus.html"}],"reference":{"reference":"CodeSystem/lma-administreringsstatus"},"name":"LMA Administreringsstatus","description":"Status för läkemedelsadministrering. **Omvårdnadslager.**\nDokumenteras av hälso- och sjukvårdspersonal. (HSLF-FS 2016:40)","exampleBoolean":false,"groupingId":"Terminology"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"CodeSystem-lma-anslutningsstatus.html"}],"reference":{"reference":"CodeSystem/lma-anslutningsstatus"},"name":"LMA Anslutningsstatus","description":"Kommunikationsstatus för läkemedelsautomat mot LMA-plattformen.\n**Enhetslager.** Rapporteras av plattformen baserat på nätverksobservation.\n(IHE SDPi/BICEPS: BICEPS MDib ConnectedState)","exampleBoolean":false,"groupingId":"Terminology"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:resource"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-LMAAutomat.html"}],"reference":{"reference":"StructureDefinition/LMAAutomat"},"name":"LMA Automat","description":"Fysisk läkemedelsautomat registrerad som medicinteknisk produkt\n(MDR 2017/745). Lager: enhetslager.\n\nAttributen driftsstatus, anslutningsstatus och batteriNivå tillhör **enhetslagret**\nmen modelleras **inte** direkt på Device-resursen. De bör i stället antingen:\n- hämtas i realtid via `DeviceMetric`-resursen\n  (se https://hl7.org/fhir/R4/devicemetric.html), eller\n- lagras som `Observation` om de mäts vid en viss frekvens eller händelse.\n\nSe avsnitt 6.1 i standarden för principiell motivering (IHE SDPi/BICEPS).","exampleBoolean":false,"groupingId":"ProfilesCore"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:extension"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-ext-lma-batch.html"}],"reference":{"reference":"StructureDefinition/ext-lma-batch"},"name":"LMA Batchnummer","description":"Batchnummer (lottnummer) för det läkemedel som fylldes på i\nautomaten. Krävs för spårbarhet vid läkemedelsåterkallelse per LVFS 2012:14.\n\nBatchnumret tillhandahålls av apoteket/dosaktören och registreras vid påfyllnad.","exampleBoolean":false,"groupingId":"Extensions"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:resource"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-LMABrukare.html"}],"reference":{"reference":"StructureDefinition/LMABrukare"},"name":"LMA Brukare","description":"Brukare med insatsen läkemedelsautomat inom socialtjänst och\nkommunal hälso- och sjukvård. Lager: omvårdnadslager.\n\nI PDL-kontext benämns samma person *patient*; FHIR-resursen Patient används\ni båda sammanhangen. Ankarpunkten för alla personrelaterade händelseresurser.","exampleBoolean":false,"groupingId":"ProfilesCore"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"CodeSystem-lma-driftsstatus.html"}],"reference":{"reference":"CodeSystem/lma-driftsstatus"},"name":"LMA Driftsstatus","description":"Driftsstatus för läkemedelsautomat. **Enhetslager.**\nRapporteras av automaten och avser enhetens egna drifttillstånd,\noberoende av omvårdnadsflöden. (IHE SDPi/BICEPS: MDib OperatingMode)","exampleBoolean":false,"groupingId":"Terminology"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:resource"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-LMAKoppling.html"}],"reference":{"reference":"StructureDefinition/LMAKoppling"},"name":"LMA Koppling","description":"Kopplingen brukare–automat. Representerar det administrativa\nbeslutet att en brukare betjänas av en specifik automat under en tidsavgränsad\nperiod. Lager: enhetslager.\n\n**FHIR-migreringsbana:** I FHIR R4 används `DeviceUseStatement`. I FHIR R5/R6\nersätts denna resurs av `DeviceAssociation` med tydligare semantik. IG:ns\nprofil är designad för att underlätta framtida migrering: logiska attribut\när namngivna i enlighet med R5-resursen.","exampleBoolean":false,"groupingId":"ProfilesCore"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"CodeSystem-lma-kopplingsstatus.html"}],"reference":{"reference":"CodeSystem/lma-kopplingsstatus"},"name":"LMA Kopplingsstatus","description":"Status för kopplingen brukare–automat. **Enhetslager.**","exampleBoolean":false,"groupingId":"Terminology"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:resource"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-LMALakemedelsadministrering.html"}],"reference":{"reference":"StructureDefinition/LMALakemedelsadministrering"},"name":"LMA Läkemedelsadministrering","description":"Dokumentation av att behörig hälso- och sjukvårdspersonal\nadministrerade läkemedlet till brukaren (tillförsel till kroppen).\nLager: omvårdnadslager.\n\nVarje post är ett **oföränderligt event** (immutable event). Korrektioner\nhanteras via ny post med `partOf`-referens till ursprungsposten.\n\n**Lageruppdelning av orsakskoder:**\nKodurval `VS-Administreringsorsak` tillhör **omvårdnadslagret** och innehåller\nenbart omvårdnadsbedömda orsaker: brukare-avböjde, brukare-ej-anträffad,\nmedicinsk-orsak. Tekniska felkoder från automaten (enhetslager) ingår **inte**\n– dessa representeras i `LMALakemedelsoverlamnande.statusReason`.","exampleBoolean":false,"groupingId":"ProfilesCore"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:resource"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-LMALakemedelsoverlamnande.html"}],"reference":{"reference":"StructureDefinition/LMALakemedelsoverlamnande"},"name":"LMA Läkemedelsöverlämnande","description":"Automatens överlämning av läkemedel vid schemalagd tidpunkt.\nLager: enhetslager.\n\nAutomaten **överlämnar** – den administrerar inte. Klassen benämns\nLäkemedelsöverlämnande för att skilja automatens handling från apotekets\ndosförpackande (dosdispensering). Se ANMÄRKNING i standardens avsnitt 6.4.7.\n\n**Lageruppdelning av felkoder:**\n- `statusReason` (felkod) tillhör **enhetslagret**: mekaniskt-fel, produkt-slut, sensorfel.\n- Dessa koder ska **inte** förekomma i `MedicationAdministration.statusReason`\n  (omvårdnadslagret).","exampleBoolean":false,"groupingId":"ProfilesCore"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"StructureDefinition:resource"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"StructureDefinition-LMAPafyllnad.html"}],"reference":{"reference":"StructureDefinition/LMAPafyllnad"},"name":"LMA Påfyllnad","description":"Registrering av att dosrullen eller läkemedelsförrådet fyllts\npå i en automat. Lager: enhetslager.\n\nBatchnummer (LVFS 2012:14) ska anges för att möjliggöra spårbarhet vid\nläkemedelsåterkallelse.","exampleBoolean":false,"groupingId":"ProfilesCore"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationguide-page","valueUri":"CodeSystem-lma-overlamninsfelkod.html"}],"reference":{"reference":"CodeSystem/lma-overlamninsfelkod"},"name":"LMA Överlämningsfelkod","description":"Felkod för misslyckad överlämning. **Enhetslager.**\nTekniska felkoder från automaten. Ska **inte** förekomma i\nMedicationAdministration.statusReason (omvårdnadslagret).","exampleBoolean":false,"groupingId":"Terminology"},{"extension":[{"url":"http://hl7.org/fhir/tools/StructureDefinition/resource-information","valueString":"CodeSystem"},{"url":"http://hl7.org/fhir/StructureDefinition/implementationg